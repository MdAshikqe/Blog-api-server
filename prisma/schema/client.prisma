model Client {
    id            String    @id @default(uuid())
    name          String
    email         String    @unique
    profilePhoto  String?
    contactNumber String?
    isDeleted     Boolean   @default(false)
    deletedAt     DateTime?
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt

    user User @relation(fields: [email], references: [email])

    @@map("clients")
}
